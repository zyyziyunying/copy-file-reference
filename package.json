{
  "name": "copy-file-reference",
  "displayName": "Copy File Reference",
  "description": "Copy an @-prefixed absolute file path with line number or range",
  "version": "0.1.4",
  "publisher": "zhouyuyang",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zyyziyunying/copy-file-reference.git"
  },
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "copy",
    "file path",
    "line number",
    "reference",
    "clipboard"
  ],
  "activationEvents": [
    "onCommand:copyFileReference.copy",
    "onCommand:copyFileReference.withRange",
    "onCommand:copyFileReference.withFolder",
    "onCommand:copyFileReference.pathOnly"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "copyFileReference.copy",
        "title": "Copy File Reference"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "copyFileReference.copy",
          "group": "1_copy"
        }
      ]
    },
    "keybindings": [
      {
        "key": "alt+r",
        "command": "copyFileReference.copy",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "^18.0.0",
    "typescript": "^5.3.0"
  }
}
